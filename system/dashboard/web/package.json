{
  "name": "fenlie-dashboard-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "refresh:panel": "node ./scripts/run-python.mjs ../../scripts/build_operator_task_visual_panel.py --review-dir ../../output/review --dashboard-dist ./public",
    "refresh:data": "node ./scripts/run-python.mjs ../../scripts/build_dashboard_frontend_snapshot.py --workspace ../../.. --public-dir ./public",
    "dev": "npm run refresh:panel && npm run refresh:data && vite --configLoader runner --host 127.0.0.1 --port 5173 --strictPort",
    "build": "npm run refresh:panel && npm run refresh:data && vite build --configLoader runner",
    "strip:internal": "node ./scripts/run-python.mjs ../../scripts/strip_dashboard_internal_surface.py --dist-dir ./dist",
    "preview": "vite preview --configLoader runner --host 127.0.0.1 --port 5173 --strictPort",
    "verify:public-surface": "node ./scripts/run-python.mjs ../../scripts/run_dashboard_public_acceptance.py --workspace ../../.. --strict-topology-tls",
    "smoke:workspace-routes": "node ./scripts/run-python.mjs ../../scripts/run_dashboard_workspace_artifacts_smoke.py --workspace ../../..",
    "smoke:workspace-artifacts": "node ./scripts/run-python.mjs ../../scripts/run_dashboard_workspace_artifacts_smoke.py --workspace ../../..",
    "smoke:alignment-internal": "node ./scripts/run-python.mjs ../../scripts/run_dashboard_workspace_artifacts_smoke.py --workspace ../../.. --mode internal_alignment",
    "smoke:alignment-internal-manual-probe": "node ./scripts/run-python.mjs ../../scripts/run_dashboard_workspace_artifacts_smoke.py --workspace ../../.. --mode internal_alignment_manual_probe",
    "smoke:terminal-internal-focus": "node ./scripts/run-python.mjs ../../scripts/run_dashboard_workspace_artifacts_smoke.py --workspace ../../.. --mode internal_terminal_focus",
    "smoke:graph-home": "node ./scripts/run-python.mjs ../../scripts/run_dashboard_workspace_artifacts_smoke.py --workspace ../../.. --mode graph_home",
    "smoke:graph-home-narrow": "node ./scripts/run-python.mjs ../../scripts/run_dashboard_workspace_artifacts_smoke.py --workspace ../../.. --mode graph_home_narrow",
    "smoke:graph-home-pipeline": "node ./scripts/run-python.mjs ../../scripts/run_dashboard_workspace_artifacts_smoke.py --workspace ../../.. --mode graph_home_pipeline",
    "feedback:publish": "node ./scripts/run-python.mjs ../../scripts/publish_conversation_feedback_autopublish_internal.py --review-dir ../../output/review",
    "feedback:publish-refresh": "bash -lc 'node ./scripts/run-python.mjs ../../scripts/publish_conversation_feedback_autopublish_internal.py --review-dir ../../output/review \"$@\" && node ./scripts/run-python.mjs ../../scripts/run_operator_panel_refresh.py --workspace ../../..' --",
    "feedback:publish-manual": "node ./scripts/run-python.mjs ../../scripts/publish_conversation_feedback_manual_internal.py --review-dir ../../output/review",
    "feedback:publish-manual-refresh": "bash -lc 'node ./scripts/run-python.mjs ../../scripts/publish_conversation_feedback_manual_internal.py --review-dir ../../output/review \"$@\" && node ./scripts/run-python.mjs ../../scripts/run_operator_panel_refresh.py --workspace ../../..' --",
    "test:dashboard-python-contracts": "node ./scripts/run-python.mjs -m pytest -q ../../tests/test_build_dashboard_frontend_snapshot_script.py ../../tests/test_run_operator_panel_refresh_script.py ../../tests/test_run_dashboard_workspace_artifacts_smoke_script.py ../../tests/test_run_dashboard_public_topology_smoke_script.py ../../tests/test_run_dashboard_public_acceptance_script.py ../../tests/test_publish_conversation_feedback_autopublish_internal_script.py ../../tests/test_publish_conversation_feedback_manual_internal_script.py ../../tests/test_build_conversation_feedback_projection_internal_script.py ../../tests/test_dashboard_feedback_publish_refresh_contract.py ../../tests/test_dashboard_feedback_publish_manual_contract.py ../../tests/test_dashboard_release_checklist_contract.py",
    "test": "vitest run --configLoader runner",
    "cf:preflight": "env -u HTTP_PROXY -u HTTPS_PROXY node ./scripts/cloudflare-preflight.mjs",
    "cf:whoami": "env -u HTTP_PROXY -u HTTPS_PROXY node ./scripts/cloudflare-wrangler.mjs whoami",
    "cf:deploy": "npm run cf:preflight && npm run build && npm run strip:internal && env -u HTTP_PROXY -u HTTPS_PROXY node ./scripts/cloudflare-wrangler.mjs pages deploy dist --project-name fenlie-dashboard-web --branch main --commit-dirty=true",
    "verify:release-checklist": "npm run build && npm test && npx tsc --noEmit && npm run test:dashboard-python-contracts && npm run smoke:workspace-routes -- --skip-build && npm run smoke:alignment-internal -- --skip-build && npm run smoke:terminal-internal-focus -- --skip-build && npm run smoke:graph-home -- --skip-build && npm run smoke:graph-home-narrow -- --skip-build && npm run smoke:graph-home-pipeline -- --skip-build && npm run verify:public-surface -- --skip-workspace-build"
  },
  "dependencies": {
    "echarts": "6.0.0",
    "echarts-for-react": "3.0.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "jsdom": "27.4.0",
    "typescript": "^5.9.3",
    "vite": "7.3.1",
    "vitest": "3.2.4"
  }
}
