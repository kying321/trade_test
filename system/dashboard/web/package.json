{
  "name": "fenlie-dashboard-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "refresh:panel": "python3 ../../scripts/build_operator_task_visual_panel.py --review-dir ../../output/review --dashboard-dist ./public",
    "refresh:data": "python3 ../../scripts/build_dashboard_frontend_snapshot.py --workspace ../../.. --public-dir ./public",
    "dev": "npm run refresh:panel && npm run refresh:data && vite --host 127.0.0.1 --port 5173 --strictPort",
    "build": "npm run refresh:panel && npm run refresh:data && vite build",
    "strip:internal": "python3 ../../scripts/strip_dashboard_internal_surface.py --dist-dir ./dist",
    "preview": "vite preview --host 127.0.0.1 --port 5173 --strictPort",
    "verify:public-surface": "python3 ../../scripts/run_dashboard_public_acceptance.py --workspace ../../..",
    "verify:release-checklist": "npm run build && npm test && npx tsc --noEmit && npm run smoke:workspace-routes -- --skip-build && npm run smoke:alignment-internal -- --skip-build && npm run verify:public-surface -- --skip-workspace-build",
    "smoke:workspace-routes": "python3 ../../scripts/run_dashboard_workspace_artifacts_smoke.py --workspace ../../..",
    "smoke:workspace-artifacts": "python3 ../../scripts/run_dashboard_workspace_artifacts_smoke.py --workspace ../../..",
    "smoke:alignment-internal": "python3 ../../scripts/run_dashboard_workspace_artifacts_smoke.py --workspace ../../.. --mode internal_alignment",
    "smoke:alignment-internal-manual-probe": "python3 ../../scripts/run_dashboard_workspace_artifacts_smoke.py --workspace ../../.. --mode internal_alignment_manual_probe",
    "feedback:publish": "python3 ../../scripts/publish_conversation_feedback_autopublish_internal.py --review-dir ../../output/review",
    "feedback:publish-refresh": "bash -lc 'python3 ../../scripts/publish_conversation_feedback_autopublish_internal.py --review-dir ../../output/review \"$@\" && python3 ../../scripts/run_operator_panel_refresh.py --workspace ../../..' --",
    "feedback:publish-manual": "python3 ../../scripts/publish_conversation_feedback_manual_internal.py --review-dir ../../output/review",
    "feedback:publish-manual-refresh": "bash -lc 'python3 ../../scripts/publish_conversation_feedback_manual_internal.py --review-dir ../../output/review \"$@\" && python3 ../../scripts/run_operator_panel_refresh.py --workspace ../../..' --",
    "test": "vitest run",
    "cf:preflight": "env -u HTTP_PROXY -u HTTPS_PROXY node ./scripts/cloudflare-preflight.mjs",
    "cf:whoami": "env -u HTTP_PROXY -u HTTPS_PROXY node ./scripts/cloudflare-wrangler.mjs whoami",
    "cf:deploy": "npm run cf:preflight && npm run build && npm run strip:internal && env -u HTTP_PROXY -u HTTPS_PROXY node ./scripts/cloudflare-wrangler.mjs pages deploy dist --project-name fenlie-dashboard-web --branch main --commit-dirty=true"
  },
  "dependencies": {
    "echarts": "6.0.0",
    "echarts-for-react": "3.0.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "jsdom": "27.4.0",
    "typescript": "^5.9.3",
    "vite": "7.3.1",
    "vitest": "3.2.4"
  }
}
